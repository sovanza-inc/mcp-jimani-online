# Jimani Online MCP — configuration

# Port the MCP server listens on (default 3102)
MCP_PORT=3102

# Secret used to authenticate clients connecting to this MCP server
# (not the Jimani API itself). Change before deploying.
MCP_API_KEY=change-me-in-production

# Jimani Open API base URL
JIMANI_API_BASE=https://openapi.jimani.online

# Default Jimani credentials — optional.
# Clients can also authenticate per-session via the `authenticate` tool.
# For OAuth Client Credentials flow (recommended):
JIMANI_CLIENT_ID=
JIMANI_PARTNER_ID=

# Alternative: static API key authentication (bypasses /api/Token)
JIMANI_API_KEY=
